{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "@vetlla/db#generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@vetlla/db#generate"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build", "@vetlla/db#generate"]
    },
    "test": {
      "dependsOn": ["^build", "@vetlla/db#generate"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "@vetlla/db#generate": {
      "cache": false
    },
    "generate": {
      "cache": false
    },
    "migrate": {
      "cache": false,
      "persistent": false
    },
    "seed": {
      "cache": false
    }
  }
}
