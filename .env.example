# ---------------------------------------------------------------------------
# Vetlla — variables de entorno (copia a .env y rellena)
# Recuerda: TODO dato/servicio debe residir en la UE (requisito legal RGPD).
# ---------------------------------------------------------------------------

# Postgres (docker-compose levanta uno local con estos valores por defecto)
POSTGRES_USER=vetlla
POSTGRES_PASSWORD=vetlla_dev_password
POSTGRES_DB=vetlla
DATABASE_URL="postgresql://vetlla:vetlla_dev_password@localhost:5432/vetlla?schema=public"

# Auth.js (NextAuth v5)
# Genera uno con: openssl rand -base64 32
AUTH_SECRET="change-me-in-production-with-openssl-rand-base64-32"
# URL pública de la app (en local)
AUTH_URL="http://localhost:3000"

# IA — Anthropic (región: cuenta/inferencia en UE)
# Los identificadores de modelo se centralizan en packages/ai y se verifican
# contra docs.claude.com; no se hardcodean a ciegas.
ANTHROPIC_API_KEY=""

# NODE_ENV lo gestionan las herramientas (Next en build/dev, Vitest en tests).
# No lo fijes aquí: forzarlo rompe el build de producción de Next.
