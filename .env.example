# ---------------------------------------------------------------------------
# Vetlla — variables de entorno (copia a .env y rellena)
# Recuerda: TODO dato/servicio debe residir en la UE (requisito legal RGPD).
# ---------------------------------------------------------------------------

# Postgres (docker-compose levanta uno local con estos valores por defecto)
POSTGRES_USER=vetlla
POSTGRES_PASSWORD=vetlla_dev_password
POSTGRES_DB=vetlla
DATABASE_URL="postgresql://vetlla:vetlla_dev_password@localhost:5432/vetlla?schema=public"

# Auth.js (NextAuth v5)
# Genera uno con: openssl rand -base64 32
AUTH_SECRET="change-me-in-production-with-openssl-rand-base64-32"
# URL pública de la app (en local)
AUTH_URL="http://localhost:3000"

# IA — packages/ai provider-agnóstico (ver ADR-0010).
# Proveedor activo: stub | vllm | bedrock | vertex. En local: stub (sin red ni GPU).
AI_PROVIDER="stub"
# Override de modelo por tier (opcional). El más específico gana:
#   AI_MODEL_<PROVIDER>_<TIER>  →  AI_MODEL_<TIER>  →  default del registro
# AI_MODEL_REASONING=""
# Ejemplo de override del modelo de extracción para vLLM (id según catálogo del proveedor):
# AI_MODEL_VLLM_EXTRACTION="mistral-small-3.2-24b"
# AI_MODEL_VLLM_REASONING="llama-3.3-70b"
# Endpoint OpenAI-compatible (mismo adaptador para vLLM/TGI self-host Y gestionado UE).
# La base URL suele incluir ya el sufijo /v1. Ejemplos (sin credenciales reales):
#   OVHcloud AI Endpoints (Gravelines, FR):
# AI_VLLM_BASE_URL="https://oai.endpoints.kepler.ai.cloud.ovh.net/v1"
#   Scaleway Generative APIs (Paris, FR):
# AI_VLLM_BASE_URL="https://api.scaleway.ai/v1"
#   vLLM/TGI self-host en GPU EU-soberana:
# AI_VLLM_BASE_URL="http://localhost:8000/v1"
# AI_VLLM_API_KEY=""
#
# ── Opción LOCAL gratis (Ollama) — probar el copiloto con un modelo real sin pagar ──
# Ollama expone un endpoint OpenAI-compatible en :11434/v1. Descarga un modelo
# (p. ej. `ollama pull qwen2.5:14b`) y descomenta estas 5 líneas (ajusta el tag a tu
# `ollama list`). En un Mac de 32 GB, qwen2.5:14b (~9 GB) va bien para AMBOS tiers junto
# con la app; el 70B NO cabe en 32 GB (ese, en OVHcloud). El catalán puede flojear en
# modelos pequeños — es esperado.
# AI_PROVIDER="vllm"
# AI_VLLM_BASE_URL="http://localhost:11434/v1"
# AI_VLLM_API_KEY="ollama"
# AI_MODEL_VLLM_EXTRACTION="qwen2.5:14b"   # o "llama3.1:8b" (más ligero)
# AI_MODEL_VLLM_REASONING="qwen2.5:14b"
# Timeout de la petición en ms (opcional, default ~60000):
# AI_VLLM_TIMEOUT_MS="60000"
# Fallback gestionado Claude-UE (región/location SIEMPRE UE):
# AI_BEDROCK_REGION="eu-central-1"
# AI_VERTEX_PROJECT=""
# AI_VERTEX_LOCATION="europe-west1"

# NODE_ENV lo gestionan las herramientas (Next en build/dev, Vitest en tests).
# No lo fijes aquí: forzarlo rompe el build de producción de Next.
