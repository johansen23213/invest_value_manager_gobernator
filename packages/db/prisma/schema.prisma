// Vetlla — esquema de datos
// H0: base mínima de multitenancy (Tenant + User).
// H1: Row-Level Security (RLS) sobre tenant_id en todas las tablas con datos.
// H2: centros, unidades, plazas/camas y expediente del residente + escalas.
// Toda tabla con datos lleva tenant_id, RLS+FORCE y su política (ver migraciones).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Roles de la plataforma. Permisos por rol + pertenencia al tenant (mínimo privilegio).
enum UserRole {
  SUPERADMIN // gestión de la plataforma (cross-tenant)
  DIRECTOR // dirección/gestor del centro
  SANITARIO // médico / enfermería
  AUXILIAR // atención directa
  FAMILIAR // solo lectura del residente vinculado
}

/// Operador / cliente del SaaS. Raíz del aislamiento multitenant.
/// Plan de suscripción del tenant. El catálogo (precio por plaza/mes y módulos
/// incluidos) vive en código (apps/web/src/lib/plans.ts): el dato persistido es
/// solo QUÉ plan tiene el tenant y hasta cuándo llega su prueba.
enum PlanTier {
  TRIAL // prueba completa, limitada en tiempo (trialEndsAt)
  ESENCIAL // gestión + atención directa + MAR
  PROFESIONAL // + copiloto IA + portal de familias
}

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  plan        PlanTier  @default(TRIAL)
  trialEndsAt DateTime? @map("trial_ends_at")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users     User[]
  centers   Center[]
  residents Resident[]
  auditLogs AuditLog[]

  @@map("tenants")
}

/// Usuario del sistema. Siempre pertenece a un tenant (salvo SUPERADMIN de plataforma).
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String    @map("password_hash")
  role         UserRole  @default(AUXILIAR)
  tenantId     String?   @map("tenant_id")
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobTitle     String?   @map("job_title") // etiqueta de función libre (Fisioterapeuta, DUE…)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  familyLinks FamilyLink[]
  authTokens  AuthToken[]

  // --- Portal de familias: solicitudes creadas/asignadas ---
  createdRequests  ServiceRequest[]        @relation("RequestCreatedBy")
  assignedRequests ServiceRequest[]        @relation("RequestAssignedTo")
  requestComments  ServiceRequestComment[]

  @@index([tenantId])
  @@map("users")
}

/// Token de un solo uso para flujos de cuenta (reset de contraseña, invitación).
/// Es INFRAESTRUCTURA DE AUTH cross-tenant (como el login por email único): no
/// lleva tenant_id ni RLS, y solo se accede con el cliente de plataforma. Se
/// guarda el HASH del token (SHA-256), nunca el valor en claro: el secreto vive
/// solo en el enlace que recibe el usuario.
enum AuthTokenType {
  PASSWORD_RESET
  INVITATION
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String        @unique @map("token_hash")
  type      AuthTokenType
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([userId])
  @@map("auth_tokens")
}

/// Vínculo entre un usuario familiar y el residente que puede consultar (portal).
model FamilyLink {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  residentId   String   @map("resident_id")
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  relationship String? // p. ej. "hijo", "cónyuge"
  // Control de privacidad (UX-20): el centro decide qué secciones ve la familia.
  canSeeCare         Boolean  @default(true) @map("can_see_care") // novedades de atención
  canSeeMedication   Boolean  @default(true) @map("can_see_medication")
  canSeeAssessments  Boolean  @default(true) @map("can_see_assessments")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, residentId])
  @@index([tenantId])
  @@index([userId])
  @@map("family_links")
}

// ---------------------------------------------------------------------------
// H2 — Centros, unidades, plazas/camas y expediente del residente
// ---------------------------------------------------------------------------

enum CenterType {
  RESIDENCIA // residencia de mayores
  CENTRO_DIA // centro de día
  VIVIENDA_TUTELADA // vivienda tutelada/supervisada
}

enum BedStatus {
  DISPONIBLE // operativa (ocupada o no; la ocupación se deriva del residente)
  FUERA_SERVICIO // baja temporal (mantenimiento, reforma...)
}

/// Grados de dependencia (Ley 39/2006).
enum DependencyGrade {
  SIN_VALORAR
  GRADO_I
  GRADO_II
  GRADO_III
}

enum Sex {
  HOMBRE
  MUJER
  OTRO
  NS_NC
}

enum ResidentStatus {
  ACTIVO
  BAJA // alta médica / fallecimiento / traslado
  PREINGRESO
}

enum ContactRelation {
  HIJO_A
  CONYUGE
  HERMANO_A
  TUTOR_LEGAL
  OTRO
}

enum AllergySeverity {
  LEVE
  MODERADA
  GRAVE
}

enum AssessmentType {
  BARTHEL      // ABVD (0–100)
  TINETTI      // marcha y equilibrio (0–28)
  // Fase 1 — escalas geriátricas adicionales
  PFEIFFER     // estado cognitivo (0–10 errores; 0 = normal)
  MEC_LOBO     // Mini-Examen Cognoscitivo Lobo (0–35; ≤23 deterioro)
  GDS_REISBERG // estadio demencia (1–7)
  NORTON       // riesgo UPP (5–20; ≤14 = riesgo alto)
  BRADEN       // riesgo UPP (6–23; ≤18 = riesgo)
  MNA          // estado nutricional (0–30)
  PAINAD       // dolor en demencia avanzada (0–10)
  DOWNTON      // riesgo de caídas (0–12; ≥3 = alto riesgo)
  LAWTON_BRODY // AIVD (0–8)
}

/// Régimen de la plaza (Ley 39/2006 + contrato con CCAA).
enum PlaceRegime {
  PRIVADA
  CONCERTADA
  PRESTACION_VINCULADA // PVS — plaza financiada por la CCAA directamente al centro
}

/// Tipo de dieta habitual del residente (protocolo disfagia + nutrición).
enum DietType {
  NORMAL
  TRITURADA
  PASTOSA
  BLANDA
  DIABETICA
  HIPOSODICA
  OTRA
}

/// Textura de líquidos según IDDSI Framework 2019.
enum LiquidTexture {
  LIBRE  // sin restricción
  NECTAR // IDDSI nivel 2
  MIEL   // IDDSI nivel 3
  PUDING // IDDSI nivel 4
}

/// Tipo de dispositivo que porta el residente.
enum DeviceType {
  SONDA_VESICAL
  SONDA_NASOGASTRICA
  OXIGENO_DOMICILIARIO
  CPAP
  MARCAPASOS
  DESFIBRILADOR_IMPLANTABLE
  PROTESIS_CADERA
  PROTESIS_RODILLA
  PROTESIS_AUDITIVA
  PROTESIS_DENTAL
  OTRO
}

/// Origen de la úlcera por presión (indicador de calidad e inspección).
enum UPPOrigin {
  INGRESO // la traía al entrar; no imputable al centro
  CENTRO  // apareció durante la estancia; indicador de calidad/inspección
}

/// Tipo de sujeción mecánica (regulado Ley 41/2002).
enum RestraintType {
  BARANDILLAS    // barandilla de cama
  CINTURON_SILLA // cinturón en silla de ruedas
  MUNEQUERAS
  CHALECO
  OTRO
}

/// Tipo de consentimiento RGPD/clínico.
enum ConsentType {
  INGRESO                  // consentimiento informado de ingreso
  IMAGEN                   // fotografía/vídeo
  PORTAL_FAMILIAS
  DATOS_SANITARIOS_EXTERNOS
  IA_ANONIMA               // uso de datos anonimizados en mejora del servicio/IA
}

/// Tipo de alergia (Fase 1: campo retrocompatible en Allergy).
enum AllergyType {
  MEDICAMENTOSA
  ALIMENTARIA
  AMBIENTAL
  LATEX
  OTRA
}

/// Centro físico del operador (residencia, centro de día o vivienda tutelada).
model Center {
  id         String     @id @default(cuid())
  tenantId   String     @map("tenant_id")
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  type       CenterType
  address    String?
  city       String?
  postalCode String?    @map("postal_code")
  phone      String?
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  units     Unit[]
  residents Resident[]

  @@index([tenantId])
  @@map("centers")
}

/// Unidad/planta dentro de un centro.
model Unit {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  centerId  String   @map("center_id")
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name      String
  floor     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  beds Bed[]

  @@index([tenantId])
  @@index([centerId])
  @@map("units")
}

/// Plaza/cama. La ocupación se deriva de si hay un residente vinculado.
model Bed {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  unitId    String    @map("unit_id")
  unit      Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  code      String // etiqueta visible, p. ej. "101-A"
  status    BedStatus @default(DISPONIBLE)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  resident Resident? // ocupante actual (0 o 1)

  @@index([tenantId])
  @@index([unitId])
  @@map("beds")
}

/// Expediente sociosanitario del residente.
model Resident {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  centerId        String          @map("center_id")
  center          Center          @relation(fields: [centerId], references: [id], onDelete: Restrict)
  bedId           String?         @unique @map("bed_id")
  bed             Bed?            @relation(fields: [bedId], references: [id], onDelete: SetNull)
  firstName       String          @map("first_name")
  lastName        String          @map("last_name")
  birthDate       DateTime?       @map("birth_date")
  sex             Sex?
  nationalId      String?         @map("national_id") // DNI/NIE
  dependencyGrade DependencyGrade @default(SIN_VALORAR) @map("dependency_grade")
  status          ResidentStatus  @default(ACTIVO)
  admissionDate   DateTime?       @map("admission_date")
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // --- Fase 1: Bloque A — Identificación y administrativo ---
  internalRecordNo   String?     @map("internal_record_no")   // nº historia interna del centro
  cip                String?                                  // Tarjeta Sanitaria / CIP autonómico
  socialSecurityNo   String?     @map("social_security_no")
  insurerName        String?     @map("insurer_name")         // mutua / aseguradora complementaria
  placeRegime        PlaceRegime @default(PRIVADA) @map("place_regime")
  dischargeDate      DateTime?   @map("discharge_date")
  dischargeReason    String?     @map("discharge_reason")     // alta médica / traslado / fallecimiento / voluntaria
  originCenter       String?     @map("origin_center")        // centro/hospital de procedencia al ingreso
  nationalIdExpiry   DateTime?   @map("national_id_expiry")   // caducidad DNI
  judicialCapacity   Boolean     @default(true) @map("judicial_capacity") // true = capaz; false = incapacitado
  legalRepName       String?     @map("legal_rep_name")       // tutor/curador/apoderado
  legalRepPhone      String?     @map("legal_rep_phone")
  legalRepEmail      String?     @map("legal_rep_email")
  advanceDirectives  Boolean?    @map("advance_directives")   // Sí/No
  advanceDirLocation String?     @map("advance_dir_location") // localización del documento
  preferredLanguage  String      @default("es") @map("preferred_language") // "es" | "ca" | otro
  bloodGroup         String?     @map("blood_group")          // A+, O-, etc.

  // --- Fase 1: Consentimientos explícitos (RGPD — resumen de estado actual) ---
  consentImage        Boolean   @default(false) @map("consent_image")
  consentFamilyPortal Boolean   @default(false) @map("consent_family_portal")
  consentAdmission    DateTime? @map("consent_admission")    // fecha firma consentimiento de ingreso

  // --- Fase 1: Bloque E — Ficha de cuidados operativos a pie de cama ---
  dietType             DietType?      @map("diet_type")
  liquidTexture        LiquidTexture? @map("liquid_texture")
  nutritionSupplements String?        @map("nutrition_supplements") // Ensure, Fortimel, etc.
  continenceType       String?        @map("continence_type")  // absorbente/sonda/control
  absorbentSize        String?        @map("absorbent_size")   // S/M/L/XL
  wanderingRisk        Boolean        @default(false) @map("wandering_risk")
  fallRisk             Boolean        @default(false) @map("fall_risk")

  contacts    EmergencyContact[]
  allergies   Allergy[]
  diagnoses   Diagnosis[]
  assessments Assessment[]
  careRecords CareRecord[]
  medications Medication[]
  administrations MedicationAdministration[]
  treatments  Treatment[]
  carePlans   CarePlan[]
  familyLinks FamilyLink[]

  // --- Fase 1: relaciones nuevas ---
  devices        ResidentDevice[]
  vaccines       Vaccine[]
  weights        WeightRecord[]
  pressureUlcers PressureUlcer[]
  falls          FallRecord[]
  restraints     Restraint[]
  consents       ConsentRecord[]
  lifeStory      LifeStory?

  // --- Portal de familias: solicitudes ---
  serviceRequests ServiceRequest[]

  @@index([tenantId])
  @@index([centerId])
  @@map("residents")
}

/// Contacto de emergencia / familiar de referencia.
model EmergencyContact {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  residentId    String          @map("resident_id")
  resident      Resident        @relation(fields: [residentId], references: [id], onDelete: Cascade)
  name          String
  relation      ContactRelation
  phone         String?
  email         String?
  isPrimary     Boolean         @default(false) @map("is_primary")
  // Fase 1: datos adicionales del contacto
  callOrder     Int?            @map("call_order")    // 1 = llamar primero en urgencias
  availability  String?                              // "mañanas", "tardes + fines de semana"
  postalAddress String?         @map("postal_address")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("emergency_contacts")
}

/// Alergia/intolerancia conocida.
model Allergy {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  residentId  String           @map("resident_id")
  resident    Resident         @relation(fields: [residentId], references: [id], onDelete: Cascade)
  substance   String
  severity    AllergySeverity?
  reaction    String?
  // Fase 1: tipo de alergia (retrocompatible — campo opcional)
  allergyType AllergyType?     @map("allergy_type")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("allergies")
}

/// Diagnóstico clínico.
model Diagnosis {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  residentId  String    @map("resident_id")
  resident    Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)
  code        String? // CIE-10 (opcional)
  description String
  diagnosedAt DateTime? @map("diagnosed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  medications Medication[] // M-10: prescripciones vinculadas a este diagnóstico
  treatments  Treatment[]  // M-09: tratamientos con este diagnóstico de referencia

  @@index([tenantId])
  @@index([residentId])
  @@map("diagnoses")
}

/// Cabecera de tratamiento (M-09): agrupa líneas de prescripción bajo un
/// objetivo clínico común, con un diagnóstico de referencia opcional.
/// Sigue el modelo de ResiPlus que el sector conoce (tratamiento -> líneas).
model Treatment {
  id          String     @id @default(cuid())
  tenantId    String     @map("tenant_id")
  residentId  String     @map("resident_id")
  resident    Resident   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  name        String // p. ej. "Control de la hipertensión"
  diagnosisId String?    @map("diagnosis_id")
  diagnosis   Diagnosis? @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  startDate   DateTime   @default(now()) @map("start_date")
  endDate     DateTime?  @map("end_date")
  notes       String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  medications Medication[]

  @@index([tenantId])
  @@index([residentId])
  @@index([diagnosisId])
  @@map("treatments")
}

/// Valoración mediante escala (Barthel, Tinetti...).
model Assessment {
  id           String         @id @default(cuid())
  tenantId     String         @map("tenant_id")
  residentId   String         @map("resident_id")
  resident     Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type         AssessmentType
  score        Int
  details      Json? // desglose por ítems (opcional)
  notes        String?
  assessedAt   DateTime       @map("assessed_at")
  assessedById String?        @map("assessed_by_id") // user.id (sin FK; trazado en AuditLog futuro)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("assessments")
}

// ---------------------------------------------------------------------------
// H3 — Atención directa offline-first
// ---------------------------------------------------------------------------

enum CareRecordType {
  CONSTANTES // tensión, FC, temperatura, SatO2...
  ABVD // actividades básicas de la vida diaria
  DEPOSICION
  INGESTA
  INCIDENCIA
}

enum SyncStatus {
  SYNCED
  CONFLICT // hubo conflicto en la última fusión (ver SyncConflict)
}

enum ConflictWinner {
  SERVER
  CLIENT
}

/// Registro de atención directa. Creado a pie de cama, posiblemente offline.
/// La idempotencia se garantiza por (tenant_id, client_id): reenviar no duplica.
model CareRecord {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  residentId      String         @map("resident_id")
  resident        Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type            CareRecordType
  clientId        String         @map("client_id") // uuid generado en el dispositivo
  payload         Json // valores estructurados (varían por tipo)
  fieldTimestamps Json           @map("field_timestamps") // campo -> ISO timestamp (LWW por campo)
  recordedAt      DateTime       @map("recorded_at") // momento clínico (del dispositivo)
  authorId        String         @map("author_id") // user.id que registró
  syncStatus      SyncStatus     @default(SYNCED) @map("sync_status")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  conflicts SyncConflict[]

  @@unique([tenantId, clientId])
  @@index([tenantId])
  @@index([residentId])
  @@map("care_records")
}

/// Registro de conflicto de sincronización (last-write-wins por campo).
model SyncConflict {
  id           String         @id @default(cuid())
  tenantId     String         @map("tenant_id")
  careRecordId String         @map("care_record_id")
  careRecord   CareRecord     @relation(fields: [careRecordId], references: [id], onDelete: Cascade)
  field        String
  serverValue  Json?          @map("server_value")
  clientValue  Json?          @map("client_value")
  winner       ConflictWinner
  resolvedAt   DateTime       @default(now()) @map("resolved_at")
  // Revisión humana de la divergencia (R-CONF): null = pendiente de revisar.
  // El LWW ya resolvió el dato; esto registra que un humano lo ha validado.
  reviewedAt   DateTime?      @map("reviewed_at")
  reviewedById String?        @map("reviewed_by_id")

  @@index([tenantId])
  @@index([careRecordId])
  @@index([tenantId, reviewedAt])
  @@map("sync_conflicts")
}

// ---------------------------------------------------------------------------
// H4 — Medicación (prescripción + MAR) y PIA (plan individualizado)
// ---------------------------------------------------------------------------

enum MedicationRoute {
  ORAL
  SUBLINGUAL
  SUBCUTANEA
  INTRAMUSCULAR
  INTRAVENOSA
  TOPICA
  INHALATORIA
  TRANSDERMICA
  RECTAL
  OCULAR
  NASAL
  OTRA
}

enum MedicationType {
  CRONICO
  AGUDO
  PRN
}

enum MedAdminStatus {
  ADMINISTRADO
  NO_ADMINISTRADO
  RECHAZADO
}

enum CarePlanStatus {
  ACTIVO
  CERRADO
}

enum GoalStatus {
  PENDIENTE
  EN_PROGRESO
  CONSEGUIDO
  CANCELADO
}

/// Prescripción de medicación. `times` son las horas de pauta (HH:MM) del día.
model Medication {
  id             String           @id @default(cuid())
  tenantId       String           @map("tenant_id")
  residentId     String           @map("resident_id")
  resident       Resident         @relation(fields: [residentId], references: [id], onDelete: Cascade)
  name           String
  dose           String
  route          MedicationRoute?
  unit           String?          // forma farmacéutica: comprimido, cápsula, solución…
  times          Json             // array de "HH:MM"
  // M-11: dosis distinta por franja/hora. array [{ "time": "HH:MM", "dose": "2 comp" }].
  // Cuando una hora aparece aquí, su dosis prevalece sobre `dose` (que es la dosis base).
  momentDoses    Json?            @map("moment_doses")
  daysOfWeek     Json?            @map("days_of_week") // array [0–6] (0=domingo); null=todos los días
  type           MedicationType?
  startDate      DateTime         @map("start_date")
  endDate        DateTime?        @map("end_date")
  instructions   String?
  active         Boolean          @default(true)
  prescribedById String?          @map("prescribed_by_id")
  // M-10: vínculo opcional de la prescripción a un diagnóstico del residente.
  diagnosisId    String?          @map("diagnosis_id")
  diagnosis      Diagnosis?       @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  // M-09: línea dentro de una cabecera de tratamiento (opcional).
  treatmentId    String?          @map("treatment_id")
  treatment      Treatment?       @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  administrations MedicationAdministration[]

  @@index([tenantId])
  @@index([residentId])
  @@index([diagnosisId])
  @@index([treatmentId])
  @@map("medications")
}

/// Registro de administración (MAR). Idempotente por (tenant, medicación, hora pautada).
/// Offline-first (ADR-0012): la identidad del evento ES la clave natural; `recordedAt`
/// (momento de registro en el dispositivo) decide el last-write-wins POR EVENTO.
model MedicationAdministration {
  id               String         @id @default(cuid())
  tenantId         String         @map("tenant_id")
  residentId       String         @map("resident_id")
  resident         Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  medicationId     String         @map("medication_id")
  medication       Medication     @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  scheduledAt      DateTime       @map("scheduled_at")
  status           MedAdminStatus
  administeredAt   DateTime?      @map("administered_at")
  administeredById String?        @map("administered_by_id")
  notes            String?
  recordedAt       DateTime       @default(now()) @map("recorded_at") // timestamp LWW del evento
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  conflicts MedicationSyncConflict[]

  @@unique([tenantId, medicationId, scheduledAt])
  @@index([tenantId])
  @@index([residentId])
  @@map("medication_administrations")
}

/// Conflicto de sincronización del MAR (ADR-0012). A diferencia de SyncConflict
/// (LWW por campo), una administración es un hecho atómico: se conserva el evento
/// completo de cada lado (server/client) y quién ganó, para revisión clínica.
model MedicationSyncConflict {
  id               String                   @id @default(cuid())
  tenantId         String                   @map("tenant_id")
  administrationId String                   @map("administration_id")
  administration   MedicationAdministration @relation(fields: [administrationId], references: [id], onDelete: Cascade)
  serverEvent      Json                     @map("server_event")
  clientEvent      Json                     @map("client_event")
  winner           ConflictWinner
  resolvedAt       DateTime                 @default(now()) @map("resolved_at")
  // Revisión humana de la divergencia (R-CONF): null = pendiente de revisar.
  reviewedAt       DateTime?                @map("reviewed_at")
  reviewedById     String?                  @map("reviewed_by_id")

  @@index([tenantId])
  @@index([administrationId])
  @@index([tenantId, reviewedAt])
  @@map("medication_sync_conflicts")
}

/// Plan Individualizado de Atención (PIA/PAI).
model CarePlan {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  residentId  String         @map("resident_id")
  resident    Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  title       String
  status      CarePlanStatus @default(ACTIVO)
  startDate   DateTime       @default(now()) @map("start_date")
  notes       String?
  createdById String?        @map("created_by_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  goals   CarePlanGoal[]
  reviews CarePlanReview[]

  @@index([tenantId])
  @@index([residentId])
  @@map("care_plans")
}

/// Objetivo dentro de un PIA.
model CarePlanGoal {
  id            String     @id @default(cuid())
  tenantId      String     @map("tenant_id")
  carePlanId    String     @map("care_plan_id")
  carePlan      CarePlan   @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  description   String
  status        GoalStatus @default(PENDIENTE)
  targetDate    DateTime?  @map("target_date")
  progressNotes String?    @map("progress_notes")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([carePlanId])
  @@map("care_plan_goals")
}

/// Revisión/seguimiento de un PIA.
model CarePlanReview {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  carePlanId   String   @map("care_plan_id")
  carePlan     CarePlan @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  reviewDate   DateTime @default(now()) @map("review_date")
  summary      String
  reviewedById String?  @map("reviewed_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([carePlanId])
  @@map("care_plan_reviews")
}

// ---------------------------------------------------------------------------
// Trazabilidad / RGPD — registro de actividad sobre datos personales (art. 9)
// ---------------------------------------------------------------------------

/// Registro de auditoría append-only: quién hizo qué, cuándo y sobre qué entidad.
/// Inmutable: la aplicación no expone update/delete y un trigger bloquea UPDATE.
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId    String?  @map("actor_id") // user.id que ejecuta la acción
  actorEmail String?  @map("actor_email") // desnormalizado para trazabilidad estable
  action     String // CREATE | UPDATE | DELETE | ADMINISTER | RECORD | LOGIN ...
  entity     String // Resident | Medication | CareRecord | CarePlan ...
  entityId   String?  @map("entity_id")
  summary    String? // descripción legible de la acción
  metadata   Json? // detalles estructurados (opcional)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Fase 1 — Expediente sociosanitario ampliado
// ---------------------------------------------------------------------------

/// Dispositivos que porta el residente (sonda, oxígeno, marcapasos, prótesis…).
/// Un residente puede tener varios simultáneamente.
model ResidentDevice {
  id          String     @id @default(cuid())
  tenantId    String     @map("tenant_id")
  residentId  String     @map("resident_id")
  resident    Resident   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type        DeviceType
  description String?    // detalle libre ("Sonda Foley 16F", "Marcapasos Medtronic")
  since       DateTime?  // fecha de implantación/colocación
  notes       String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("resident_devices")
}

/// Vacunación del residente (gripe, COVID, neumococo, tétanos…).
model Vaccine {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  residentId String   @map("resident_id")
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type       String   // "gripe", "COVID", "neumococo", "tétanos", etc.
  date       DateTime
  lot        String?  // lote del vial — trazabilidad
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("vaccines")
}

/// Registro periódico de peso y talla (detectar desnutrición o retención de líquidos).
model WeightRecord {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  residentId   String   @map("resident_id")
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  weightKg     Float    @map("weight_kg")
  heightCm     Float?   @map("height_cm") // solo si cambia; suele medirse al ingreso
  bmi          Float?                     // calculado y almacenado para tendencias
  recordedAt   DateTime @map("recorded_at")
  recordedById String?  @map("recorded_by_id")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("weight_records")
}

/// Úlcera por presión (UPP) activa o resuelta. Indicador de calidad e inspección.
model PressureUlcer {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  residentId   String     @map("resident_id")
  resident     Resident   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  location     String     // localización anatómica (sacro, talón, trocánter…)
  stage        Int        // 1–4 (escala NPUAP/EPUAP)
  onsetDate    DateTime   @map("onset_date")
  resolvedDate DateTime?  @map("resolved_date")
  acquired     UPPOrigin  // INGRESO | CENTRO — indicador de calidad/legal
  notes        String?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  curings UPPCuring[]

  @@index([tenantId])
  @@index([residentId])
  @@map("pressure_ulcers")
}

/// Registro de cura de una UPP.
model UPPCuring {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  pressureUlcerId String        @map("pressure_ulcer_id")
  pressureUlcer   PressureUlcer @relation(fields: [pressureUlcerId], references: [id], onDelete: Cascade)
  date            DateTime
  treatment       String        // descripción del apósito y técnica
  evolution       String?       // mejor / igual / peor / resuelto
  doneById        String?       @map("done_by_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([pressureUlcerId])
  @@map("upp_curings")
}

/// Caída registrada. Registro obligatorio (indicador de calidad e inspección).
model FallRecord {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  residentId   String   @map("resident_id")
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  occurredAt   DateTime @map("occurred_at")
  location     String?  // habitación, pasillo, baño…
  circumstances String? // qué estaba haciendo el residente
  injuries     String?  // contusión, fractura, herida…
  witnessed    Boolean  @default(false)
  measures     String?  // medidas adoptadas tras la caída
  reportedById String?  @map("reported_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("fall_records")
}

/// Sujeción mecánica (MUY REGULADO: Ley 41/2002 + jurisprudencia).
/// Requiere prescripción médica + consentimiento + revisión periódica + registro.
/// La inspección puede suspender la licencia si no hay protocolo.
model Restraint {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  residentId      String        @map("resident_id")
  resident        Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type            RestraintType
  justification   String        // motivo clínico documentado (obligatorio)
  prescribedById  String?       @map("prescribed_by_id") // sanitario que prescribe
  prescribedAt    DateTime      @map("prescribed_at")
  consentObtained Boolean       @default(false) @map("consent_obtained")
  consentDate     DateTime?     @map("consent_date")
  consentBy       String?       @map("consent_by")  // quién firma (residente o representante)
  active          Boolean       @default(true)
  endDate         DateTime?     @map("end_date")
  endReason       String?       @map("end_reason")
  reviewedAt      DateTime?     @map("reviewed_at") // última revisión periódica
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("restraints")
}

/// Registro de consentimientos RGPD/clínicos (art. 7 RGPD — trazabilidad explícita).
/// No reemplaza los campos boolean en Resident (resumen de estado actual);
/// esta tabla es el historial de cambios de consentimiento.
model ConsentRecord {
  id         String      @id @default(cuid())
  tenantId   String      @map("tenant_id")
  residentId String      @map("resident_id")
  resident   Resident    @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type       ConsentType
  granted    Boolean     // true = concede / false = revoca
  grantedBy  String?     @map("granted_by") // nombre de quien firma
  date       DateTime
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("consent_records")
}

// ---------------------------------------------------------------------------
// Portal de familias — Solicitudes (REQ-001..REQ-011)
// ---------------------------------------------------------------------------

/// Categorías de solicitud.
enum ServiceRequestCategory {
  ADMINISTRACION
  DOCUMENTACION
  VISITAS
  ACTIVIDADES
  MANTENIMIENTO
  ALIMENTACION
  COMUNICACION
  OBJETOS_PERSONALES
  INCIDENCIA_APP
  OTRA
}

/// Estado del ciclo de vida de una solicitud.
enum ServiceRequestStatus {
  RECIBIDA
  ASIGNADA
  EN_CURSO
  PENDIENTE_INFO
  RESUELTA
  CERRADA
  REABIERTA
}

/// Prioridad de la solicitud (determina el SLA).
enum ServiceRequestPriority {
  BAJA
  NORMAL
  ALTA
  URGENTE
}

// ---------------------------------------------------------------------------

/// Historia de vida del residente (atención centrada en la persona, UNE 158101).
/// Un único registro por residente; se actualiza por upsert.
model LifeStory {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  residentId      String   @unique @map("resident_id")
  resident        Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  profession      String?  // ocupación/profesión anterior
  hobbies         String?  // aficiones y actividades que le gustaban
  music           String?  // géneros o artistas favoritos
  importantPeople String?  @map("important_people") // familia, amigos clave
  religion        String?  // religión y prácticas (dieta, fiestas, ritos)
  preferences     String?  // preferencias en el aseo, comidas favoritas, rutinas
  notes           String?  // campo libre para el trabajador social
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("life_stories")
}

// ---------------------------------------------------------------------------
// Portal de familias — Solicitudes e incidencias (REQ-001..REQ-011)
// ---------------------------------------------------------------------------
//
// NOTA Q-004: los adjuntos de fichero (REQ-006) requieren object storage,
// bloqueado hasta Q-004. Los comentarios de texto (ServiceRequestComment)
// cubren la evidencia textual por ahora. Implementar adjuntos cuando
// se resuelva Q-004 (añadir tabla ServiceRequestAttachment con URL firmada).

/// Solicitud de servicio creada por un familiar para el centro.
/// Incluye SLA, ciclo de vida completo (REQ-003), notificación (REQ-008)
/// y valoración post-resolución CSAT (REQ-009).
model ServiceRequest {
  id              String                   @id @default(cuid())
  tenantId        String                   @map("tenant_id")
  residentId      String                   @map("resident_id")
  resident        Resident                 @relation(fields: [residentId], references: [id], onDelete: Cascade)
  createdById     String                   @map("created_by_id")
  createdBy       User                     @relation("RequestCreatedBy", fields: [createdById], references: [id])
  assignedToId    String?                  @map("assigned_to_id")
  assignedTo      User?                    @relation("RequestAssignedTo", fields: [assignedToId], references: [id])
  category        ServiceRequestCategory
  status          ServiceRequestStatus     @default(RECIBIDA)
  priority        ServiceRequestPriority   @default(NORMAL)
  title           String
  description     String
  slaDueAt        DateTime?                @map("sla_due_at")   // calculado al crear (REQ-007)
  firstResponseAt DateTime?                @map("first_response_at") // 1ª respuesta del staff (REQ-005)
  resolvedAt      DateTime?                @map("resolved_at")
  closedAt        DateTime?                @map("closed_at")
  satisfactionScore Int?                   @map("satisfaction_score") // CSAT 1-5 (REQ-009)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  comments ServiceRequestComment[]

  @@index([tenantId])
  @@index([residentId])
  @@index([createdById])
  @@index([status])
  @@map("service_requests")
}

/// Comentario sobre una solicitud (texto). El staff puede añadir comentarios
/// internos (internal=true) no visibles al familiar.
/// Los adjuntos de fichero quedan bloqueados hasta Q-004 (véase nota arriba).
model ServiceRequestComment {
  id        String         @id @default(cuid())
  tenantId  String         @map("tenant_id")
  requestId String         @map("request_id")
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String         @map("author_id")
  author    User           @relation(fields: [authorId], references: [id])
  body      String
  internal  Boolean        @default(false) // si true: solo visible al staff, nunca al familiar
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([requestId])
  @@map("service_request_comments")
}
