// Vetlla — esquema de datos
// H0: base mínima de multitenancy (Tenant + User).
// H1: Row-Level Security (RLS) sobre tenant_id en todas las tablas con datos.
// H2: centros, unidades, plazas/camas y expediente del residente + escalas.
// Toda tabla con datos lleva tenant_id, RLS+FORCE y su política (ver migraciones).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Roles de la plataforma. Permisos por rol + pertenencia al tenant (mínimo privilegio).
enum UserRole {
  SUPERADMIN // gestión de la plataforma (cross-tenant)
  DIRECTOR // dirección/gestor del centro
  SANITARIO // médico / enfermería
  AUXILIAR // atención directa
  FAMILIAR // solo lectura del residente vinculado
}

/// Operador / cliente del SaaS. Raíz del aislamiento multitenant.
/// Plan de suscripción del tenant. El catálogo (precio por plaza/mes y módulos
/// incluidos) vive en código (apps/web/src/lib/plans.ts): el dato persistido es
/// solo QUÉ plan tiene el tenant y hasta cuándo llega su prueba.
enum PlanTier {
  TRIAL // prueba completa, limitada en tiempo (trialEndsAt)
  ESENCIAL // gestión + atención directa + MAR
  PROFESIONAL // + copiloto IA + portal de familias
}

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  plan        PlanTier  @default(TRIAL)
  trialEndsAt DateTime? @map("trial_ends_at")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users     User[]
  centers   Center[]
  residents Resident[]
  auditLogs AuditLog[]

  @@map("tenants")
}

/// Usuario del sistema. Siempre pertenece a un tenant (salvo SUPERADMIN de plataforma).
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String    @map("password_hash")
  role         UserRole  @default(AUXILIAR)
  tenantId     String?   @map("tenant_id")
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobTitle     String?   @map("job_title") // etiqueta de función libre (Fisioterapeuta, DUE…)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  familyLinks FamilyLink[]
  authTokens  AuthToken[]

  // --- Portal de familias: solicitudes creadas/asignadas ---
  createdRequests  ServiceRequest[]        @relation("RequestCreatedBy")
  assignedRequests ServiceRequest[]        @relation("RequestAssignedTo")
  requestComments  ServiceRequestComment[]

  // --- Comunicaciones ---
  authoredAnnouncements Announcement[]        @relation("AnnouncementAuthor")
  announcementReceipts  AnnouncementReceipt[] @relation("AnnouncementReceiptUser")
  createdThreads        MessageThread[]       @relation("ThreadCreatedBy")
  messages              Message[]             @relation("MessageAuthor")

  // --- Visitas ---
  requestedVisits Visit[] @relation("VisitRequestedBy")

  // --- Documentación clínica ---
  nursingNotes NursingNote[] @relation("NursingNoteAuthor")
  medicalNotes MedicalNote[] @relation("MedicalNoteAuthor")

  // --- Épica B ---
  dischargeRecords   DischargeRecord[]
  socialReports      SocialReport[]
  wellbeingProfiles  WellbeingProfile[]

  // --- Épica C ---
  menuItemsCreated   MenuItem[]        @relation("MenuItemCreatedBy")
  intakeRecorded     IntakeRecord[]    @relation("IntakeRecordedBy")

  // --- Épica D: turnos del personal ---
  shiftAssignments        ShiftAssignment[]  @relation("ShiftAssignmentUser")
  shiftAssignmentSubs     ShiftAssignment[]  @relation("ShiftAssignmentSubstitute")
  shiftAssignmentsCreated ShiftAssignment[]  @relation("ShiftAssignmentCreatedBy")
  shiftHandoversClosed    ShiftHandover[]

  @@index([tenantId])
  @@map("users")
}

/// Token de un solo uso para flujos de cuenta (reset de contraseña, invitación).
/// Es INFRAESTRUCTURA DE AUTH cross-tenant (como el login por email único): no
/// lleva tenant_id ni RLS, y solo se accede con el cliente de plataforma. Se
/// guarda el HASH del token (SHA-256), nunca el valor en claro: el secreto vive
/// solo en el enlace que recibe el usuario.
enum AuthTokenType {
  PASSWORD_RESET
  INVITATION
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String        @unique @map("token_hash")
  type      AuthTokenType
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([userId])
  @@map("auth_tokens")
}

/// Vínculo entre un usuario familiar y el residente que puede consultar (portal).
model FamilyLink {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  residentId   String   @map("resident_id")
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  relationship String? // p. ej. "hijo", "cónyuge"
  // Control de privacidad (UX-20): el centro decide qué secciones ve la familia.
  canSeeCare         Boolean  @default(true) @map("can_see_care") // novedades de atención
  canSeeMedication   Boolean  @default(true) @map("can_see_medication")
  canSeeAssessments  Boolean  @default(true) @map("can_see_assessments")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, residentId])
  @@index([tenantId])
  @@index([userId])
  @@map("family_links")
}

// ---------------------------------------------------------------------------
// H2 — Centros, unidades, plazas/camas y expediente del residente
// ---------------------------------------------------------------------------

enum CenterType {
  RESIDENCIA // residencia de mayores
  CENTRO_DIA // centro de día
  VIVIENDA_TUTELADA // vivienda tutelada/supervisada
}

enum BedStatus {
  DISPONIBLE // operativa (ocupada o no; la ocupación se deriva del residente)
  FUERA_SERVICIO // baja temporal (mantenimiento, reforma...)
}

/// Grados de dependencia (Ley 39/2006).
enum DependencyGrade {
  SIN_VALORAR
  GRADO_I
  GRADO_II
  GRADO_III
}

enum Sex {
  HOMBRE
  MUJER
  OTRO
  NS_NC
}

enum ResidentStatus {
  ACTIVO
  BAJA // alta médica / fallecimiento / traslado
  PREINGRESO
}

enum ContactRelation {
  HIJO_A
  CONYUGE
  HERMANO_A
  TUTOR_LEGAL
  OTRO
}

enum AllergySeverity {
  LEVE
  MODERADA
  GRAVE
}

enum AssessmentType {
  BARTHEL      // ABVD (0–100)
  TINETTI      // marcha y equilibrio (0–28)
  // Fase 1 — escalas geriátricas adicionales
  PFEIFFER     // estado cognitivo (0–10 errores; 0 = normal)
  MEC_LOBO     // Mini-Examen Cognoscitivo Lobo (0–35; ≤23 deterioro)
  GDS_REISBERG // estadio demencia (1–7)
  NORTON       // riesgo UPP (5–20; ≤14 = riesgo alto)
  BRADEN       // riesgo UPP (6–23; ≤18 = riesgo)
  MNA          // estado nutricional (0–30)
  PAINAD       // dolor en demencia avanzada (0–10)
  DOWNTON      // riesgo de caídas (0–12; ≥3 = alto riesgo)
  LAWTON_BRODY // AIVD (0–8)
}

/// Régimen de la plaza (Ley 39/2006 + contrato con CCAA).
enum PlaceRegime {
  PRIVADA
  CONCERTADA
  PRESTACION_VINCULADA // PVS — plaza financiada por la CCAA directamente al centro
}

/// Tipo de dieta habitual del residente (protocolo disfagia + nutrición).
enum DietType {
  NORMAL
  TRITURADA
  PASTOSA
  BLANDA
  DIABETICA
  HIPOSODICA
  OTRA
}

/// Textura de líquidos según IDDSI Framework 2019.
enum LiquidTexture {
  LIBRE  // sin restricción
  NECTAR // IDDSI nivel 2
  MIEL   // IDDSI nivel 3
  PUDING // IDDSI nivel 4
}

/// Tipo de dispositivo que porta el residente.
enum DeviceType {
  SONDA_VESICAL
  SONDA_NASOGASTRICA
  OXIGENO_DOMICILIARIO
  CPAP
  MARCAPASOS
  DESFIBRILADOR_IMPLANTABLE
  PROTESIS_CADERA
  PROTESIS_RODILLA
  PROTESIS_AUDITIVA
  PROTESIS_DENTAL
  OTRO
}

/// Origen de la úlcera por presión (indicador de calidad e inspección).
enum UPPOrigin {
  INGRESO // la traía al entrar; no imputable al centro
  CENTRO  // apareció durante la estancia; indicador de calidad/inspección
}

/// Tipo de sujeción mecánica (regulado Ley 41/2002).
enum RestraintType {
  BARANDILLAS    // barandilla de cama
  CINTURON_SILLA // cinturón en silla de ruedas
  MUNEQUERAS
  CHALECO
  OTRO
}

/// Tipo de consentimiento RGPD/clínico.
enum ConsentType {
  INGRESO                  // consentimiento informado de ingreso
  IMAGEN                   // fotografía/vídeo
  PORTAL_FAMILIAS
  DATOS_SANITARIOS_EXTERNOS
  IA_ANONIMA               // uso de datos anonimizados en mejora del servicio/IA
}

/// Tipo de alergia (Fase 1: campo retrocompatible en Allergy).
enum AllergyType {
  MEDICAMENTOSA
  ALIMENTARIA
  AMBIENTAL
  LATEX
  OTRA
}

/// Centro físico del operador (residencia, centro de día o vivienda tutelada).
model Center {
  id         String     @id @default(cuid())
  tenantId   String     @map("tenant_id")
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  type       CenterType
  address    String?
  city       String?
  postalCode String?    @map("postal_code")
  phone      String?
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  units          Unit[]
  residents      Resident[]
  visitSlotConfigs VisitSlotConfig[]
  menuItems      MenuItem[]

  // --- Épica D: turnos del personal ---
  shiftTemplates  ShiftTemplate[]
  shiftHandovers  ShiftHandover[]

  @@index([tenantId])
  @@map("centers")
}

/// Unidad/planta dentro de un centro.
model Unit {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  centerId  String   @map("center_id")
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name      String
  floor     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  beds          Bed[]
  announcements Announcement[]

  // --- Épica D: turnos del personal ---
  shiftTemplates   ShiftTemplate[]
  shiftAssignments ShiftAssignment[]
  shiftHandovers   ShiftHandover[]

  @@index([tenantId])
  @@index([centerId])
  @@map("units")
}

/// Plaza/cama. La ocupación se deriva de si hay un residente vinculado.
model Bed {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  unitId    String    @map("unit_id")
  unit      Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  code      String // etiqueta visible, p. ej. "101-A"
  status    BedStatus @default(DISPONIBLE)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  resident Resident? // ocupante actual (0 o 1)

  @@index([tenantId])
  @@index([unitId])
  @@map("beds")
}

/// Expediente sociosanitario del residente.
model Resident {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  centerId        String          @map("center_id")
  center          Center          @relation(fields: [centerId], references: [id], onDelete: Restrict)
  bedId           String?         @unique @map("bed_id")
  bed             Bed?            @relation(fields: [bedId], references: [id], onDelete: SetNull)
  firstName       String          @map("first_name")
  lastName        String          @map("last_name")
  birthDate       DateTime?       @map("birth_date")
  sex             Sex?
  nationalId      String?         @map("national_id") // DNI/NIE
  dependencyGrade DependencyGrade @default(SIN_VALORAR) @map("dependency_grade")
  status          ResidentStatus  @default(ACTIVO)
  admissionDate   DateTime?       @map("admission_date")
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // --- Fase 1: Bloque A — Identificación y administrativo ---
  internalRecordNo   String?     @map("internal_record_no")   // nº historia interna del centro
  cip                String?                                  // Tarjeta Sanitaria / CIP autonómico
  socialSecurityNo   String?     @map("social_security_no")
  insurerName        String?     @map("insurer_name")         // mutua / aseguradora complementaria
  placeRegime        PlaceRegime @default(PRIVADA) @map("place_regime")
  dischargeDate      DateTime?   @map("discharge_date")
  dischargeReason    String?     @map("discharge_reason")     // alta médica / traslado / fallecimiento / voluntaria
  originCenter       String?     @map("origin_center")        // centro/hospital de procedencia al ingreso
  nationalIdExpiry   DateTime?   @map("national_id_expiry")   // caducidad DNI
  judicialCapacity   Boolean     @default(true) @map("judicial_capacity") // true = capaz; false = incapacitado
  legalRepName       String?     @map("legal_rep_name")       // tutor/curador/apoderado
  legalRepPhone      String?     @map("legal_rep_phone")
  legalRepEmail      String?     @map("legal_rep_email")
  advanceDirectives  Boolean?    @map("advance_directives")   // Sí/No
  advanceDirLocation String?     @map("advance_dir_location") // localización del documento
  preferredLanguage  String      @default("es") @map("preferred_language") // "es" | "ca" | otro
  bloodGroup         String?     @map("blood_group")          // A+, O-, etc.

  // --- Fase 1: Consentimientos explícitos (RGPD — resumen de estado actual) ---
  consentImage        Boolean   @default(false) @map("consent_image")
  consentFamilyPortal Boolean   @default(false) @map("consent_family_portal")
  consentAdmission    DateTime? @map("consent_admission")    // fecha firma consentimiento de ingreso

  // --- Fase 1: Bloque E — Ficha de cuidados operativos a pie de cama ---
  dietType             DietType?      @map("diet_type")
  liquidTexture        LiquidTexture? @map("liquid_texture")
  nutritionSupplements String?        @map("nutrition_supplements") // Ensure, Fortimel, etc.
  continenceType       String?        @map("continence_type")  // absorbente/sonda/control
  absorbentSize        String?        @map("absorbent_size")   // S/M/L/XL
  wanderingRisk        Boolean        @default(false) @map("wandering_risk")
  fallRisk             Boolean        @default(false) @map("fall_risk")

  contacts    EmergencyContact[]
  allergies   Allergy[]
  diagnoses   Diagnosis[]
  assessments Assessment[]
  careRecords CareRecord[]
  medications Medication[]
  administrations MedicationAdministration[]
  treatments  Treatment[]
  carePlans   CarePlan[]
  familyLinks FamilyLink[]

  // --- Fase 1: relaciones nuevas ---
  devices        ResidentDevice[]
  vaccines       Vaccine[]
  weights        WeightRecord[]
  pressureUlcers PressureUlcer[]
  falls          FallRecord[]
  restraints     Restraint[]
  consents       ConsentRecord[]
  lifeStory      LifeStory?

  // --- Portal de familias: solicitudes ---
  serviceRequests ServiceRequest[]

  // --- Comunicaciones ---
  announcements  Announcement[]
  messageThreads MessageThread[]

  // --- Visitas ---
  visits Visit[]

  // --- Documentación clínica (staff-only) ---
  nursingNotes NursingNote[]
  medicalNotes MedicalNote[]

  // --- Épica B (staff-only) ---
  dischargeRecords  DischargeRecord[]
  socialReports     SocialReport[]
  wellbeingProfile  WellbeingProfile?

  // --- Épica C ---
  intakeRecords     IntakeRecord[]

  @@index([tenantId])
  @@index([centerId])
  @@map("residents")
}

/// Contacto de emergencia / familiar de referencia.
model EmergencyContact {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  residentId    String          @map("resident_id")
  resident      Resident        @relation(fields: [residentId], references: [id], onDelete: Cascade)
  name          String
  relation      ContactRelation
  phone         String?
  email         String?
  isPrimary     Boolean         @default(false) @map("is_primary")
  // Fase 1: datos adicionales del contacto
  callOrder     Int?            @map("call_order")    // 1 = llamar primero en urgencias
  availability  String?                              // "mañanas", "tardes + fines de semana"
  postalAddress String?         @map("postal_address")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("emergency_contacts")
}

/// Alergia/intolerancia conocida.
model Allergy {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  residentId  String           @map("resident_id")
  resident    Resident         @relation(fields: [residentId], references: [id], onDelete: Cascade)
  substance   String
  severity    AllergySeverity?
  reaction    String?
  // Fase 1: tipo de alergia (retrocompatible — campo opcional)
  allergyType AllergyType?     @map("allergy_type")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("allergies")
}

/// Diagnóstico clínico.
model Diagnosis {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  residentId  String    @map("resident_id")
  resident    Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)
  code        String? // CIE-10 (opcional)
  description String
  diagnosedAt DateTime? @map("diagnosed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  medications Medication[] // M-10: prescripciones vinculadas a este diagnóstico
  treatments  Treatment[]  // M-09: tratamientos con este diagnóstico de referencia

  @@index([tenantId])
  @@index([residentId])
  @@map("diagnoses")
}

/// Cabecera de tratamiento (M-09): agrupa líneas de prescripción bajo un
/// objetivo clínico común, con un diagnóstico de referencia opcional.
/// Sigue el modelo de ResiPlus que el sector conoce (tratamiento -> líneas).
model Treatment {
  id          String     @id @default(cuid())
  tenantId    String     @map("tenant_id")
  residentId  String     @map("resident_id")
  resident    Resident   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  name        String // p. ej. "Control de la hipertensión"
  diagnosisId String?    @map("diagnosis_id")
  diagnosis   Diagnosis? @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  startDate   DateTime   @default(now()) @map("start_date")
  endDate     DateTime?  @map("end_date")
  notes       String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  medications Medication[]

  @@index([tenantId])
  @@index([residentId])
  @@index([diagnosisId])
  @@map("treatments")
}

/// Valoración mediante escala (Barthel, Tinetti...).
model Assessment {
  id           String         @id @default(cuid())
  tenantId     String         @map("tenant_id")
  residentId   String         @map("resident_id")
  resident     Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type         AssessmentType
  score        Int
  details      Json? // desglose por ítems (opcional)
  notes        String?
  assessedAt   DateTime       @map("assessed_at")
  assessedById String?        @map("assessed_by_id") // user.id (sin FK; trazado en AuditLog futuro)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("assessments")
}

// ---------------------------------------------------------------------------
// H3 — Atención directa offline-first
// ---------------------------------------------------------------------------

enum CareRecordType {
  CONSTANTES // tensión, FC, temperatura, SatO2...
  ABVD // actividades básicas de la vida diaria
  DEPOSICION
  INGESTA
  INCIDENCIA
}

enum SyncStatus {
  SYNCED
  CONFLICT // hubo conflicto en la última fusión (ver SyncConflict)
}

enum ConflictWinner {
  SERVER
  CLIENT
}

/// Registro de atención directa. Creado a pie de cama, posiblemente offline.
/// La idempotencia se garantiza por (tenant_id, client_id): reenviar no duplica.
model CareRecord {
  id              String         @id @default(cuid())
  tenantId        String         @map("tenant_id")
  residentId      String         @map("resident_id")
  resident        Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type            CareRecordType
  clientId        String         @map("client_id") // uuid generado en el dispositivo
  payload         Json // valores estructurados (varían por tipo)
  fieldTimestamps Json           @map("field_timestamps") // campo -> ISO timestamp (LWW por campo)
  recordedAt      DateTime       @map("recorded_at") // momento clínico (del dispositivo)
  authorId        String         @map("author_id") // user.id que registró
  syncStatus      SyncStatus     @default(SYNCED) @map("sync_status")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  conflicts SyncConflict[]

  @@unique([tenantId, clientId])
  @@index([tenantId])
  @@index([residentId])
  @@map("care_records")
}

/// Registro de conflicto de sincronización (last-write-wins por campo).
model SyncConflict {
  id           String         @id @default(cuid())
  tenantId     String         @map("tenant_id")
  careRecordId String         @map("care_record_id")
  careRecord   CareRecord     @relation(fields: [careRecordId], references: [id], onDelete: Cascade)
  field        String
  serverValue  Json?          @map("server_value")
  clientValue  Json?          @map("client_value")
  winner       ConflictWinner
  resolvedAt   DateTime       @default(now()) @map("resolved_at")
  // Revisión humana de la divergencia (R-CONF): null = pendiente de revisar.
  // El LWW ya resolvió el dato; esto registra que un humano lo ha validado.
  reviewedAt   DateTime?      @map("reviewed_at")
  reviewedById String?        @map("reviewed_by_id")

  @@index([tenantId])
  @@index([careRecordId])
  @@index([tenantId, reviewedAt])
  @@map("sync_conflicts")
}

// ---------------------------------------------------------------------------
// H4 — Medicación (prescripción + MAR) y PIA (plan individualizado)
// ---------------------------------------------------------------------------

enum MedicationRoute {
  ORAL
  SUBLINGUAL
  SUBCUTANEA
  INTRAMUSCULAR
  INTRAVENOSA
  TOPICA
  INHALATORIA
  TRANSDERMICA
  RECTAL
  OCULAR
  NASAL
  OTRA
}

enum MedicationType {
  CRONICO
  AGUDO
  PRN
}

enum MedAdminStatus {
  ADMINISTRADO
  NO_ADMINISTRADO
  RECHAZADO
}

enum CarePlanStatus {
  ACTIVO
  CERRADO
}

enum GoalStatus {
  PENDIENTE
  EN_PROGRESO
  CONSEGUIDO
  CANCELADO
}

/// Prescripción de medicación. `times` son las horas de pauta (HH:MM) del día.
model Medication {
  id             String           @id @default(cuid())
  tenantId       String           @map("tenant_id")
  residentId     String           @map("resident_id")
  resident       Resident         @relation(fields: [residentId], references: [id], onDelete: Cascade)
  name           String
  dose           String
  route          MedicationRoute?
  unit           String?          // forma farmacéutica: comprimido, cápsula, solución…
  times          Json             // array de "HH:MM"
  // M-11: dosis distinta por franja/hora. array [{ "time": "HH:MM", "dose": "2 comp" }].
  // Cuando una hora aparece aquí, su dosis prevalece sobre `dose` (que es la dosis base).
  momentDoses    Json?            @map("moment_doses")
  daysOfWeek     Json?            @map("days_of_week") // array [0–6] (0=domingo); null=todos los días
  type           MedicationType?
  startDate      DateTime         @map("start_date")
  endDate        DateTime?        @map("end_date")
  instructions   String?
  active         Boolean          @default(true)
  prescribedById String?          @map("prescribed_by_id")
  // M-10: vínculo opcional de la prescripción a un diagnóstico del residente.
  diagnosisId    String?          @map("diagnosis_id")
  diagnosis      Diagnosis?       @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  // M-09: línea dentro de una cabecera de tratamiento (opcional).
  treatmentId    String?          @map("treatment_id")
  treatment      Treatment?       @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  administrations MedicationAdministration[]

  @@index([tenantId])
  @@index([residentId])
  @@index([diagnosisId])
  @@index([treatmentId])
  @@map("medications")
}

/// Registro de administración (MAR). Idempotente por (tenant, medicación, hora pautada).
/// Offline-first (ADR-0012): la identidad del evento ES la clave natural; `recordedAt`
/// (momento de registro en el dispositivo) decide el last-write-wins POR EVENTO.
model MedicationAdministration {
  id               String         @id @default(cuid())
  tenantId         String         @map("tenant_id")
  residentId       String         @map("resident_id")
  resident         Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  medicationId     String         @map("medication_id")
  medication       Medication     @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  scheduledAt      DateTime       @map("scheduled_at")
  status           MedAdminStatus
  administeredAt   DateTime?      @map("administered_at")
  administeredById String?        @map("administered_by_id")
  notes            String?
  recordedAt       DateTime       @default(now()) @map("recorded_at") // timestamp LWW del evento
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  conflicts MedicationSyncConflict[]

  @@unique([tenantId, medicationId, scheduledAt])
  @@index([tenantId])
  @@index([residentId])
  @@map("medication_administrations")
}

/// Conflicto de sincronización del MAR (ADR-0012). A diferencia de SyncConflict
/// (LWW por campo), una administración es un hecho atómico: se conserva el evento
/// completo de cada lado (server/client) y quién ganó, para revisión clínica.
model MedicationSyncConflict {
  id               String                   @id @default(cuid())
  tenantId         String                   @map("tenant_id")
  administrationId String                   @map("administration_id")
  administration   MedicationAdministration @relation(fields: [administrationId], references: [id], onDelete: Cascade)
  serverEvent      Json                     @map("server_event")
  clientEvent      Json                     @map("client_event")
  winner           ConflictWinner
  resolvedAt       DateTime                 @default(now()) @map("resolved_at")
  // Revisión humana de la divergencia (R-CONF): null = pendiente de revisar.
  reviewedAt       DateTime?                @map("reviewed_at")
  reviewedById     String?                  @map("reviewed_by_id")

  @@index([tenantId])
  @@index([administrationId])
  @@index([tenantId, reviewedAt])
  @@map("medication_sync_conflicts")
}

/// Plan Individualizado de Atención (PIA/PAI).
model CarePlan {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  residentId  String         @map("resident_id")
  resident    Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  title       String
  status      CarePlanStatus @default(ACTIVO)
  startDate   DateTime       @default(now()) @map("start_date")
  notes       String?
  createdById String?        @map("created_by_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  goals   CarePlanGoal[]
  reviews CarePlanReview[]

  @@index([tenantId])
  @@index([residentId])
  @@map("care_plans")
}

/// Objetivo dentro de un PIA.
model CarePlanGoal {
  id            String     @id @default(cuid())
  tenantId      String     @map("tenant_id")
  carePlanId    String     @map("care_plan_id")
  carePlan      CarePlan   @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  description   String
  status        GoalStatus @default(PENDIENTE)
  targetDate    DateTime?  @map("target_date")
  progressNotes String?    @map("progress_notes")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([carePlanId])
  @@map("care_plan_goals")
}

/// Revisión/seguimiento de un PIA.
model CarePlanReview {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  carePlanId   String   @map("care_plan_id")
  carePlan     CarePlan @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  reviewDate   DateTime @default(now()) @map("review_date")
  summary      String
  reviewedById String?  @map("reviewed_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([carePlanId])
  @@map("care_plan_reviews")
}

// ---------------------------------------------------------------------------
// Trazabilidad / RGPD — registro de actividad sobre datos personales (art. 9)
// ---------------------------------------------------------------------------

/// Registro de auditoría append-only: quién hizo qué, cuándo y sobre qué entidad.
/// Inmutable: la aplicación no expone update/delete y un trigger bloquea UPDATE y DELETE.
///
/// NOTA (ALTO-02, 2026-06-12): tenantId es un string libre, sin FK de BD.
/// - Para eventos de tenant: contiene el UUID del tenant (como siempre).
/// - Para eventos de plataforma (SUPERADMIN sin tenant): contiene 'PLATFORM'.
/// La FK fue eliminada en migración 20260612140000 para poder registrar eventos
/// de plataforma. El aislamiento entre tenants lo garantiza RLS (no la FK).
/// La relación Prisma se mantiene como optional para queries de conveniencia.
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  actorId    String?  @map("actor_id") // user.id que ejecuta la acción
  actorEmail String?  @map("actor_email") // desnormalizado para trazabilidad estable
  action     String // CREATE | UPDATE | DELETE | ADMINISTER | RECORD | LOGIN ...
  entity     String // Resident | Medication | CareRecord | CarePlan ...
  entityId   String?  @map("entity_id")
  summary    String? // descripción legible de la acción
  metadata   Json? // detalles estructurados (opcional)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Fase 1 — Expediente sociosanitario ampliado
// ---------------------------------------------------------------------------

/// Dispositivos que porta el residente (sonda, oxígeno, marcapasos, prótesis…).
/// Un residente puede tener varios simultáneamente.
model ResidentDevice {
  id          String     @id @default(cuid())
  tenantId    String     @map("tenant_id")
  residentId  String     @map("resident_id")
  resident    Resident   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type        DeviceType
  description String?    // detalle libre ("Sonda Foley 16F", "Marcapasos Medtronic")
  since       DateTime?  // fecha de implantación/colocación
  notes       String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("resident_devices")
}

/// Vacunación del residente (gripe, COVID, neumococo, tétanos…).
model Vaccine {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  residentId String   @map("resident_id")
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type       String   // "gripe", "COVID", "neumococo", "tétanos", etc.
  date       DateTime
  lot        String?  // lote del vial — trazabilidad
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("vaccines")
}

/// Registro periódico de peso y talla (detectar desnutrición o retención de líquidos).
model WeightRecord {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  residentId   String   @map("resident_id")
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  weightKg     Float    @map("weight_kg")
  heightCm     Float?   @map("height_cm") // solo si cambia; suele medirse al ingreso
  bmi          Float?                     // calculado y almacenado para tendencias
  recordedAt   DateTime @map("recorded_at")
  recordedById String?  @map("recorded_by_id")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("weight_records")
}

/// Úlcera por presión (UPP) activa o resuelta. Indicador de calidad e inspección.
model PressureUlcer {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  residentId   String     @map("resident_id")
  resident     Resident   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  location     String     // localización anatómica (sacro, talón, trocánter…)
  stage        Int        // 1–4 (escala NPUAP/EPUAP)
  onsetDate    DateTime   @map("onset_date")
  resolvedDate DateTime?  @map("resolved_date")
  acquired     UPPOrigin  // INGRESO | CENTRO — indicador de calidad/legal
  notes        String?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  curings UPPCuring[]

  @@index([tenantId])
  @@index([residentId])
  @@map("pressure_ulcers")
}

/// Registro de cura de una UPP.
model UPPCuring {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  pressureUlcerId String        @map("pressure_ulcer_id")
  pressureUlcer   PressureUlcer @relation(fields: [pressureUlcerId], references: [id], onDelete: Cascade)
  date            DateTime
  treatment       String        // descripción del apósito y técnica
  evolution       String?       // mejor / igual / peor / resuelto
  doneById        String?       @map("done_by_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([pressureUlcerId])
  @@map("upp_curings")
}

/// Caída registrada. Registro obligatorio (indicador de calidad e inspección).
model FallRecord {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  residentId   String   @map("resident_id")
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  occurredAt   DateTime @map("occurred_at")
  location     String?  // habitación, pasillo, baño…
  circumstances String? // qué estaba haciendo el residente
  injuries     String?  // contusión, fractura, herida…
  witnessed    Boolean  @default(false)
  measures     String?  // medidas adoptadas tras la caída
  reportedById String?  @map("reported_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("fall_records")
}

/// Sujeción mecánica (MUY REGULADO: Ley 41/2002 + jurisprudencia).
/// Requiere prescripción médica + consentimiento + revisión periódica + registro.
/// La inspección puede suspender la licencia si no hay protocolo.
model Restraint {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  residentId      String        @map("resident_id")
  resident        Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type            RestraintType
  justification   String        // motivo clínico documentado (obligatorio)
  prescribedById  String?       @map("prescribed_by_id") // sanitario que prescribe
  prescribedAt    DateTime      @map("prescribed_at")
  consentObtained Boolean       @default(false) @map("consent_obtained")
  consentDate     DateTime?     @map("consent_date")
  consentBy       String?       @map("consent_by")  // quién firma (residente o representante)
  active          Boolean       @default(true)
  endDate         DateTime?     @map("end_date")
  endReason       String?       @map("end_reason")
  reviewedAt      DateTime?     @map("reviewed_at") // última revisión periódica
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("restraints")
}

/// Registro de consentimientos RGPD/clínicos (art. 7 RGPD — trazabilidad explícita).
/// No reemplaza los campos boolean en Resident (resumen de estado actual);
/// esta tabla es el historial de cambios de consentimiento.
model ConsentRecord {
  id         String      @id @default(cuid())
  tenantId   String      @map("tenant_id")
  residentId String      @map("resident_id")
  resident   Resident    @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type       ConsentType
  granted    Boolean     // true = concede / false = revoca
  grantedBy  String?     @map("granted_by") // nombre de quien firma
  date       DateTime
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([residentId])
  @@map("consent_records")
}

// ---------------------------------------------------------------------------
// Visitas (VIS-001..VIS-010)
// ---------------------------------------------------------------------------

/// Estado del ciclo de vida de una visita.
enum VisitStatus {
  SOLICITADA   // creada por el familiar, pendiente de aprobación
  CONFIRMADA   // aprobada (auto o manual) — se genera qrCode
  RECHAZADA    // rechazada por el staff
  CANCELADA    // cancelada por familiar o staff antes de la visita
  EN_CURSO     // familiar en el centro (check-in realizado)
  COMPLETADA   // visita finalizada (check-out)
  NO_SHOW      // no se presentó — franja pasada sin check-in
}

/// Configuración de franjas horarias de visita por centro.
/// El staff (DIRECTOR con centers:write) gestiona el calendario de franjas.
model VisitSlotConfig {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  centerId    String   @map("center_id")
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      @map("day_of_week")   // 0=domingo … 6=sábado
  startTime   String   @map("start_time")    // "HH:MM" 24h
  endTime     String   @map("end_time")      // "HH:MM" 24h
  capacity    Int                            // visitas simultáneas admitidas
  autoApprove Boolean  @default(true)  @map("auto_approve") // VIS-003: aprobar automáticamente
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, centerId])
  @@map("visit_slot_configs")
}

/// Visita de un familiar a un residente.
/// El qrCode se genera al confirmar; recepción lo valida en el check-in.
///
/// Diseño del código QR:
///   - BASE32 de 8 caracteres (alfabeto sin 0/O/1/I): corto, legible en pantalla/papel.
///   - Se guarda en claro (es un identificador de sesión de visita, no una credencial de cuenta).
///   - Caducidad operativa: el endpoint checkInByCode rechaza códigos cuya scheduledAt
///     no sea HOY, lo que equivale a caducidad de franja sin necesidad de TTL en BD.
///   - Único por tenant (@@unique [tenantId, qrCode]) para evitar colisiones.
model Visit {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  residentId      String      @map("resident_id")
  resident        Resident    @relation(fields: [residentId], references: [id], onDelete: Cascade)
  requestedById   String      @map("requested_by_id")   // user.id del familiar
  requestedBy     User        @relation("VisitRequestedBy", fields: [requestedById], references: [id])
  scheduledAt     DateTime    @map("scheduled_at")      // inicio de la franja (UTC)
  durationMin     Int         @default(60) @map("duration_min")
  visitorNames    Json        @map("visitor_names")     // string[] — acompañantes
  status          VisitStatus @default(SOLICITADA)
  qrCode          String?     @map("qr_code")           // generado al confirmar
  checkInAt       DateTime?   @map("check_in_at")
  checkOutAt      DateTime?   @map("check_out_at")
  cancelReason    String?     @map("cancel_reason")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@unique([tenantId, qrCode])
  @@index([tenantId])
  @@index([tenantId, residentId])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, status])
  @@map("visits")
}

// ---------------------------------------------------------------------------
// Portal de familias — Solicitudes (REQ-001..REQ-011)
// ---------------------------------------------------------------------------

/// Categorías de solicitud.
enum ServiceRequestCategory {
  ADMINISTRACION
  DOCUMENTACION
  VISITAS
  ACTIVIDADES
  MANTENIMIENTO
  ALIMENTACION
  COMUNICACION
  OBJETOS_PERSONALES
  INCIDENCIA_APP
  OTRA
}

/// Estado del ciclo de vida de una solicitud.
enum ServiceRequestStatus {
  RECIBIDA
  ASIGNADA
  EN_CURSO
  PENDIENTE_INFO
  RESUELTA
  CERRADA
  REABIERTA
}

/// Prioridad de la solicitud (determina el SLA).
enum ServiceRequestPriority {
  BAJA
  NORMAL
  ALTA
  URGENTE
}

// ---------------------------------------------------------------------------

/// Historia de vida del residente (atención centrada en la persona, UNE 158101).
/// Un único registro por residente; se actualiza por upsert.
model LifeStory {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  residentId      String   @unique @map("resident_id")
  resident        Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  profession      String?  // ocupación/profesión anterior
  hobbies         String?  // aficiones y actividades que le gustaban
  music           String?  // géneros o artistas favoritos
  importantPeople String?  @map("important_people") // familia, amigos clave
  religion        String?  // religión y prácticas (dieta, fiestas, ritos)
  preferences     String?  // preferencias en el aseo, comidas favoritas, rutinas
  notes           String?  // campo libre para el trabajador social
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("life_stories")
}

// ---------------------------------------------------------------------------
// Portal de familias — Solicitudes e incidencias (REQ-001..REQ-011)
// ---------------------------------------------------------------------------
//
// NOTA Q-004: los adjuntos de fichero (REQ-006) requieren object storage,
// bloqueado hasta Q-004. Los comentarios de texto (ServiceRequestComment)
// cubren la evidencia textual por ahora. Implementar adjuntos cuando
// se resuelva Q-004 (añadir tabla ServiceRequestAttachment con URL firmada).

/// Solicitud de servicio creada por un familiar para el centro.
/// Incluye SLA, ciclo de vida completo (REQ-003), notificación (REQ-008)
/// y valoración post-resolución CSAT (REQ-009).
model ServiceRequest {
  id              String                   @id @default(cuid())
  tenantId        String                   @map("tenant_id")
  residentId      String                   @map("resident_id")
  resident        Resident                 @relation(fields: [residentId], references: [id], onDelete: Cascade)
  createdById     String                   @map("created_by_id")
  createdBy       User                     @relation("RequestCreatedBy", fields: [createdById], references: [id])
  assignedToId    String?                  @map("assigned_to_id")
  assignedTo      User?                    @relation("RequestAssignedTo", fields: [assignedToId], references: [id])
  category        ServiceRequestCategory
  status          ServiceRequestStatus     @default(RECIBIDA)
  priority        ServiceRequestPriority   @default(NORMAL)
  title           String
  description     String
  slaDueAt        DateTime?                @map("sla_due_at")   // calculado al crear (REQ-007)
  firstResponseAt DateTime?                @map("first_response_at") // 1ª respuesta del staff (REQ-005)
  resolvedAt      DateTime?                @map("resolved_at")
  closedAt        DateTime?                @map("closed_at")
  satisfactionScore Int?                   @map("satisfaction_score") // CSAT 1-5 (REQ-009)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  comments ServiceRequestComment[]

  @@index([tenantId])
  @@index([residentId])
  @@index([createdById])
  @@index([status])
  @@map("service_requests")
}

/// Comentario sobre una solicitud (texto). El staff puede añadir comentarios
/// internos (internal=true) no visibles al familiar.
/// Los adjuntos de fichero quedan bloqueados hasta Q-004 (véase nota arriba).
model ServiceRequestComment {
  id        String         @id @default(cuid())
  tenantId  String         @map("tenant_id")
  requestId String         @map("request_id")
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String         @map("author_id")
  author    User           @relation(fields: [authorId], references: [id])
  body      String
  internal  Boolean        @default(false) // si true: solo visible al staff, nunca al familiar
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([requestId])
  @@map("service_request_comments")
}

// ---------------------------------------------------------------------------
// Comunicaciones — Comunicados + Mensajería bidireccional (COM-001..COM-011)
// ---------------------------------------------------------------------------

/// Segmentación del comunicado (COM-001).
enum AnnouncementAudience {
  TODO_EL_CENTRO // todos los familiares del tenant
  POR_UNIDAD     // familiares de residentes con cama en la unidad indicada
  RESIDENTE      // familiares vinculados al residente indicado
}

/// Categoría temática del comunicado.
enum AnnouncementCategory {
  ADMINISTRACION
  VISITAS
  BIENESTAR
  DOCUMENTACION
  EVENTOS
  GENERAL
}

/// Categoría temática del hilo de mensajería (COM-003).
enum MessageThreadCategory {
  ADMINISTRACION
  VISITAS
  BIENESTAR
  DOCUMENTACION
  PAGOS
  GENERAL
}

/// Estado del hilo de mensajería.
enum MessageThreadStatus {
  ABIERTO
  CERRADO
}

/// Comunicado del centro a las familias. Puede segmentarse por centro completo,
/// unidad o residente concreto. Opcionalmente requiere acuse de recibo (COM-010).
///
/// NOTA Q-004: envío masivo de email no se hace aquí por volumen; se delega
/// a un job/queue. El router publica el comunicado y deja un TODO.
model Announcement {
  id          String                @id @default(cuid())
  tenantId    String                @map("tenant_id")
  authorId    String                @map("author_id")
  author      User                  @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  title       String
  body        String
  category    AnnouncementCategory  @default(GENERAL)
  audience    AnnouncementAudience  @default(TODO_EL_CENTRO)
  unitId      String?               @map("unit_id")
  unit        Unit?                 @relation(fields: [unitId], references: [id], onDelete: SetNull)
  residentId  String?               @map("resident_id")
  resident    Resident?             @relation(fields: [residentId], references: [id], onDelete: Cascade)
  requiresAck Boolean               @default(false) @map("requires_ack")
  publishedAt DateTime              @default(now()) @map("published_at")
  createdAt   DateTime              @default(now()) @map("created_at")

  receipts AnnouncementReceipt[]

  @@index([tenantId])
  @@index([authorId])
  @@index([publishedAt])
  @@map("announcements")
}

/// Registro de lectura y acuse de recibo de un comunicado (COM-006, COM-010).
/// Único por (announcementId, userId).
model AnnouncementReceipt {
  id             String       @id @default(cuid())
  tenantId       String       @map("tenant_id")
  announcementId String       @map("announcement_id")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation("AnnouncementReceiptUser", fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime?    @map("read_at")
  acknowledgedAt DateTime?    @map("acknowledged_at")

  @@unique([announcementId, userId])
  @@index([tenantId])
  @@index([announcementId])
  @@index([userId])
  @@map("announcement_receipts")
}

// ---------------------------------------------------------------------------
// Épica A — Notas de enfermería por turno y Evolución médica
// (RF-ENF-001..011, RF-CLI-001..006/009/011, RF-PRO-008/009)
//
// CONFIDENCIALIDAD: MedicalNote es staff-only (RF-CLI-010). NO se expone en
// el portal de familias (family.ts / portal). El familiar nunca tiene acceso
// a los evolutivos médicos a través de ningún endpoint.
//
// Permisos:
//   NursingNote — crear/actualizar: care:write (AUXILIAR, SANITARIO, DIRECTOR).
//                 leer: care:read.
//                 Decisión: care:* encaja perfectamente porque la nota de
//                 enfermería es un registro de atención directa, no un dato
//                 clínico de categoría especial. Reutilizar sin crear permiso nuevo.
//
//   MedicalNote — crear: clinical:write (SANITARIO, DIRECTOR).
//                 leer: residents:read dentro del staff.
//                 Decisión: clinical:write es el permiso correcto — los
//                 evolutivos médicos son documentación clínica firmada por
//                 personal sanitario, misma capa que diagnósticos y curas.
// ---------------------------------------------------------------------------

/// Turno de enfermería. Alineado con lib/mar.ts: Mañana 06-14, Tarde 14-22, Noche 22-06.
enum NursingNoteShift {
  MANANA  // 06:00–13:59
  TARDE   // 14:00–21:59
  NOCHE   // 22:00–05:59
}

/// Categoría temática de la nota de enfermería (RF-ENF-004).
enum NursingNoteCategory {
  GENERAL       // anotación general del turno
  INCIDENCIA    // incidente relevante durante el turno
  CURA          // cura de herida/UPP realizada en el turno
  CONDUCTA      // comportamiento / estado emocional
  SUENO         // calidad del sueño (noturno)
  DOLOR         // valoración/seguimiento del dolor
  ALIMENTACION  // ingesta y aceptación de la dieta
}

/// Nota de enfermería por turno (RF-ENF-001..011).
/// Documenta la evolución del residente durante cada turno (mañana/tarde/noche).
/// Base del traspaso de turno (RF-PRO-008/009): listForShiftHandover agrupa
/// las notas del turno actual de todos los residentes de un centro/unidad.
model NursingNote {
  id         String              @id @default(cuid())
  tenantId   String              @map("tenant_id")
  residentId String              @map("resident_id")
  resident   Resident            @relation(fields: [residentId], references: [id], onDelete: Cascade)
  authorId   String              @map("author_id")     // enfermería / auxiliar
  author     User                @relation("NursingNoteAuthor", fields: [authorId], references: [id])
  shift      NursingNoteShift
  noteDate   DateTime            @map("note_date")     // día del turno (sin hora; hora implícita en `shift`)
  body       String              // texto libre de la nota
  category   NursingNoteCategory? @default(GENERAL)
  createdAt  DateTime            @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, residentId])
  @@index([tenantId, noteDate])
  @@map("nursing_notes")
}

// ---------------------------------------------------------------------------
// Épica B — Exitus/Baja, Informe Social y Perfil de Bienestar ACP
// ---------------------------------------------------------------------------

/// Tipo de baja del residente (RF-ADM-011).
enum DischargeType {
  DEFUNCION
  VOLUNTARIA
  TRASLADO_CENTRO
  TRASLADO_HOSPITAL
  FIN_ESTANCIA
  OTRO
}

/// Tipo de anotación del evolutivo médico (RF-CLI-001/002).
enum MedicalNoteType {
  EVOLUTIVO    // seguimiento periódico del estado del residente
  EXPLORACION  // exploración física realizada por el médico
  DERIVACION   // derivación a especialista o urgencias
  VISITA       // visita del médico de cabecera o especialista externo
}

/// Evolutivo médico (RF-CLI-001..006/009/011) — staff-only (RF-CLI-010).
/// NUNCA exponer en el portal de familias ni en ningún endpoint accesible
/// al rol FAMILIAR. Requiere clinical:write para crear.
model MedicalNote {
  id         String         @id @default(cuid())
  tenantId   String         @map("tenant_id")
  residentId String         @map("resident_id")
  resident   Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  authorId   String         @map("author_id")     // médico / sanitario (clinical:write)
  author     User           @relation("MedicalNoteAuthor", fields: [authorId], references: [id])
  noteDate   DateTime       @map("note_date")     // fecha de la anotación
  type       MedicalNoteType
  reason     String?        // motivo de la visita / exploración
  body       String         // texto principal del evolutivo
  plan       String?        // plan / tratamiento derivado de esta nota
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, residentId])
  @@index([tenantId, noteDate])
  @@map("medical_notes")
}

// ---------------------------------------------------------------------------
// Épica B — Exitus/Baja (RF-ADM-011/012/013)
// ---------------------------------------------------------------------------

/// Registro de baja del residente (exitus, alta voluntaria, traslado…).
///
/// Permite histórico: un residente puede reingresar tras una baja, por eso
/// residentId NO es @unique. La transacción del router hace siempre:
///   1. Crea DischargeRecord.
///   2. Actualiza Resident.status=BAJA + dischargeDate + dischargeReason.
///   3. Libera la cama (bedId=null).
///
/// Permisos: residents:write para registrar; residents:read para ver.
/// FAMILIAR: sin acceso (staff-only como NursingNote/MedicalNote).
///
/// AuditLog: SIEMPRE. Action=DISCHARGE, summary incluye el tipo pero NO la
/// causa clínica de muerte (dato sensible; va en notes/certifiedBy).
model DischargeRecord {
  id                 String        @id @default(cuid())
  tenantId           String        @map("tenant_id")
  residentId         String        @map("resident_id")
  resident           Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type               DischargeType
  dischargedAt       DateTime      @map("discharged_at")
  reason             String?       // motivo de la baja (texto libre)
  /// Solo para DEFUNCION: nombre del médico certificante. NO es la causa clínica.
  certifiedBy        String?       @map("certified_by")
  /// Para TRASLADO_*: nombre del centro/hospital de destino.
  destination        String?
  familyNotifiedAt   DateTime?     @map("family_notified_at")
  belongingsReturned Boolean       @default(false) @map("belongings_returned")
  /// Checklist extendida (protocol del centro). JSON flexible para evitar
  /// proliferación de columnas booleanas. Campos core están en columnas tipadas.
  checklist          Json?
  notes              String?
  recordedById       String        @map("recorded_by_id")
  recordedBy         User          @relation(fields: [recordedById], references: [id])
  createdAt          DateTime      @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, residentId])
  @@index([tenantId, dischargedAt])
  @@map("discharge_records")
}

// ---------------------------------------------------------------------------
// Épica B — Informe Social (RF-SOC-001..008)
// ---------------------------------------------------------------------------

/// Informe social estructurado del residente.
///
/// Documento vivo: admite update (el trabajador social lo actualiza periódicamente).
/// Staff-only: NO se expone en el portal de familias.
///
/// Permisos: residents:write para crear/editar; residents:read para consultar.
/// Decisión: residents:write ya lo tienen DIRECTOR y SANITARIO — que es donde
/// encaja el trabajo social en el RBAC actual. No se crea un permiso nuevo
/// para evitar proliferación (AUXILIAR no puede editar, sí puede leer con residents:read).
model SocialReport {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  residentId        String    @map("resident_id")
  resident          Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)
  authorId          String    @map("author_id")
  author            User      @relation(fields: [authorId], references: [id])
  reportDate        DateTime  @map("report_date")
  /// RF-SOC-001: situación familiar
  familySituation   String?   @map("family_situation")
  /// RF-SOC-002: red de apoyo social
  supportNetwork    String?   @map("support_network")
  /// RF-SOC-003: situación económica
  economicSituation String?   @map("economic_situation")
  /// RF-SOC-004: prestaciones y subsidios (Dependencia, PVS, etc.)
  benefits          String?
  /// historial laboral / ocupacional
  workHistory       String?   @map("work_history")
  /// RF-SOC-006: valoración social global del trabajador social
  socialAssessment  String?   @map("social_assessment")
  /// RF-SOC-007: acuerdos con residente y/o familia
  agreements        String?
  /// RF-SOC-008: fecha de próxima revisión del informe
  nextReviewDate    DateTime? @map("next_review_date")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, residentId])
  @@map("social_reports")
}

// ---------------------------------------------------------------------------
// Épica B — Perfil de Bienestar ACP / UNE 158101 (RF-SOC-003..006)
// ---------------------------------------------------------------------------

/// Perfil de bienestar de la Atención Centrada en la Persona (ACP).
///
/// Un único perfil por residente (residentId @unique). Se actualiza por upsert.
///
/// Las 8 dimensiones de bienestar según UNE 158101 / modelo Schalock & Verdugo:
///   1. Bienestar emocional (emotionalWellbeing)
///   2. Bienestar físico (physicalWellbeing)
///   3. Bienestar material (materialWellbeing)
///   4. Desarrollo personal (personalDevelopment)
///   5. Autodeterminación (selfDetermination)
///   6. Relaciones interpersonales (interpersonalRelations)
///   7. Inclusión social (socialInclusion)
///   8. Derechos (rights)
///
/// Permisos: residents:write para crear/editar; residents:read para consultar.
/// FAMILIAR: sin acceso (staff-only).
/// La alerta de revisión vencida se computa con isReviewOverdue() en lib/wellbeing.ts.
model WellbeingProfile {
  id                      String    @id @default(cuid())
  tenantId                String    @map("tenant_id")
  residentId              String    @unique @map("resident_id")
  resident                Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)
  // 8 dimensiones ACP (UNE 158101)
  emotionalWellbeing      String?   @map("emotional_wellbeing")
  physicalWellbeing       String?   @map("physical_wellbeing")
  materialWellbeing       String?   @map("material_wellbeing")
  personalDevelopment     String?   @map("personal_development")
  selfDetermination       String?   @map("self_determination")
  interpersonalRelations  String?   @map("interpersonal_relations")
  socialInclusion         String?   @map("social_inclusion")
  rights                  String?
  /// RF-SOC-005: qué es importante PARA la persona (sus deseos y preferencias)
  importantToThePerson    String?   @map("important_to_the_person")
  /// RF-SOC-005: qué es importante PARA su bienestar (necesidades; lo que debe evitarse)
  importantForThePerson   String?   @map("important_for_the_person")
  /// Fecha de próxima revisión periódica (RF-SOC-007). La alerta la computa isReviewOverdue().
  nextReviewDate          DateTime? @map("next_review_date")
  updatedById             String?   @map("updated_by_id")
  updatedBy               User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, nextReviewDate])
  @@map("wellbeing_profiles")
}

// ---------------------------------------------------------------------------
// Épica C — Nutrición, Menús y Comedor (RF-NUT-001..009)
// ---------------------------------------------------------------------------

/// Franja del día para los menús e ingestas.
enum MealType {
  DESAYUNO
  COMIDA
  MERIENDA
  CENA
}

/// 14 alérgenos de declaración obligatoria (Reglamento UE 1169/2011).
/// Distinto de AllergyType (categoría de alergia del residente).
enum Allergen {
  GLUTEN
  CRUSTACEOS
  HUEVOS
  PESCADO
  CACAHUETES
  SOJA
  LACTEOS
  FRUTOS_CASCARA
  APIO
  MOSTAZA
  SESAMO
  SULFITOS
  ALTRAMUCES
  MOLUSCOS
}

/// Plato/ítem del menú diario de un centro (RF-NUT-003/004).
///
/// Datos del CENTRO, no del residente: sin residentId → no entra en dsar-registry.
/// Sí tiene tenantId → RLS ENABLE+FORCE+policy (ver migración 20260613210000).
///
/// allergens: JSON array de valores Allergen (Reglamento UE 1169/2011).
/// isAlternative: true para platos de dieta especial (no el estándar del día).
///
/// Permisos:
///   crear/editar: centers:write (dirección — ya existe).
///   leer (staff): care:read.
///   leer (familiar, RF-NUT-005): portal:read — endpoint separado menu.forFamily
///   que verifica el FamilyLink antes de exponer el menú del centro.
model MenuItem {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  centerId      String   @map("center_id")
  center        Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  date          DateTime // día del menú (se ignora la parte horaria)
  meal          MealType
  dishName      String   @map("dish_name")
  description   String?
  allergens     Json     @default("[]") // Allergen[] serializado
  isAlternative Boolean  @default(false) @map("is_alternative")
  createdById   String   @map("created_by_id")
  createdBy     User     @relation("MenuItemCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, centerId, date])
  @@map("menu_items")
}

/// Registro de ingesta estructurado por comida y residente (RF-NUT-006/007).
///
/// RELACIÓN CON CareRecord(type=INGESTA):
///   CareRecord/INGESTA es el flujo offline-first genérico de atención directa
///   (JSON libre en payload, funciona sin conectividad).
///   IntakeRecord es el registro ESTRUCTURADO con porcentaje y franja horaria,
///   destinado al panel de nutrición y las alertas de baja ingesta (RF-NUT-007).
///   Son complementarios: el auxiliar puede usar CareRecord offline a pie de cama
///   e IntakeRecord desde el comedor con conectividad. No se rompe ni duplica ninguno.
///
/// foodPct: porcentaje consumido (0-100). Validado en Zod + CHECK en BD.
///
/// DSAR: tiene residentId → declarado en dsar-registry (export:true, anonymize:'delete').
///
/// Permisos: care:write para registrar / care:read para consultar.
model IntakeRecord {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  residentId   String   @map("resident_id")
  resident     Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  date         DateTime // día + hora del registro
  meal         MealType
  foodPct      Int      @map("food_pct") // 0-100: % del plato consumido
  hydrationMl  Int?     @map("hydration_ml") // ml de líquido ingeridos (opcional)
  notes        String?
  recordedById String   @map("recorded_by_id")
  recordedBy   User     @relation("IntakeRecordedBy", fields: [recordedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, residentId, date])
  @@map("intake_records")
}

// ---------------------------------------------------------------------------
// Épica D — Cuadrantes/Turnos del personal + Cierre de turno firmado
// (RF-PRO-003/004/008/009/010/013)
//
// FUERA DE ALCANCE (decisión CIO):
//   RF-PRO-005 (generación de tareas operativas desde el PIA) y
//   RF-PRO-012 (alerta de tareas PIA vencidas) → módulo de tareas propio, épica futura.
//
// DISEÑO — enum de turno:
//   Se reutiliza NursingNoteShift (MANANA/TARDE/NOCHE) en lugar de crear StaffShift
//   con los mismos literales. Las columnas `shift` en shift_templates, shift_assignments
//   y shift_handovers son del tipo NursingNoteShift a nivel de BD. Esto garantiza
//   coherencia con lib/mar.ts, el MAR y las notas de enfermería, y evita proliferación
//   de enums semánticamente idénticos. En el router se importa NursingNoteShift
//   bajo el alias conceptual de StaffShift.
//
// PERMISOS:
//   shifts:read   → ver cuadrante/turnos (DIRECTOR, SANITARIO, AUXILIAR).
//   shifts:manage → planificar cuadrante, plantillas, ausencias, sustituciones
//                   (DIRECTOR, SUPERADMIN).
//   Cierre de turno:
//     handover.close / handover.draft → care:write / care:read (AUXILIAR+, quien
//     hace el relevo). Reutiliza el permiso existente: el cierre de turno firmado
//     es una evolución natural del módulo /relevo (clinicalNotes.nursing.
//     listForShiftHandover), que ya usa care:write/care:read.
//   FAMILIAR: sin acceso a ninguna tabla de esta épica.
//
// DSAR:
//   Ninguna de las 3 tablas tiene residentId → ninguna entra en dsar-registry.
//   shift_templates y shift_handovers son datos del centro/organización.
//   shift_assignments es dato del TRABAJADOR (no del residente): la cobertura
//   de datos del personal queda fuera del art. 15/17 del RGPD aplicado a
//   residentes. Se aplica RLS+FORCE por ser dato de tenant.
// ---------------------------------------------------------------------------

/// Estado del ciclo de vida de una asignación al cuadrante.
enum AssignmentStatus {
  PLANIFICADO  // planificado, pendiente de confirmar
  CONFIRMADO   // trabajador ha confirmado asistencia
  AUSENTE      // ausencia justificada (baja, permisos, etc.)
  SUSTITUIDO   // ausente pero cubierto por substituteUserId
}

/// Plantilla de turno por centro/unidad (RF-PRO-003).
///
/// Define el nombre, turno (reutiliza NursingNoteShift), horario orientativo
/// y el mínimo de personal (minStaff) que es la base de la alerta de
/// infra-cobertura (RF-PRO-004). Si unitId es NULL, aplica a todo el centro.
///
/// Datos del CENTRO, no del residente → no entra en dsar-registry.
/// Sí tiene tenantId → RLS ENABLE+FORCE+policy obligatorio.
///
/// Permisos: shifts:manage para crear/editar/borrar (DIRECTOR/SUPERADMIN).
///           shifts:read para leer (DIRECTOR/SANITARIO/AUXILIAR).
model ShiftTemplate {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  centerId     String           @map("center_id")
  center       Center           @relation(fields: [centerId], references: [id], onDelete: Cascade)
  unitId       String?          @map("unit_id")
  unit         Unit?            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name         String
  shift        NursingNoteShift // reutiliza el enum existente (MANANA/TARDE/NOCHE)
  startTime    String           @map("start_time")  // "HH:MM" — orientativo
  endTime      String           @map("end_time")    // "HH:MM" — orientativo
  minStaff     Int              @default(1) @map("min_staff") // base de la alerta de infra-cobertura
  active       Boolean          @default(true)
  createdById  String           @map("created_by_id")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, centerId])
  @@map("shift_templates")
}

/// Asignación de un trabajador a un turno/día (cuadrante mensual — RF-PRO-003).
///
/// Dato del TRABAJADOR (userId), NO del residente → no entra en dsar-registry.
/// @@unique([tenantId, userId, date, shift]) garantiza idempotencia: no se
/// puede duplicar la misma asignación (mismo trabajador, día y turno).
///
/// substituteUserId: quien cubre el turno si el status es AUSENTE/SUSTITUIDO.
///
/// Permisos: shifts:read para ver; shifts:manage para crear/editar/borrar.
/// Auditoría: en cambios de status (AUSENTE con sustituto, etc.).
model ShiftAssignment {
  id                String           @id @default(cuid())
  tenantId          String           @map("tenant_id")
  userId            String           @map("user_id")         // el trabajador asignado
  user              User             @relation("ShiftAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  date              DateTime         // día del turno (se ignora la parte horaria)
  shift             NursingNoteShift // reutiliza el enum existente
  unitId            String?          @map("unit_id")
  unit              Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  status            AssignmentStatus @default(PLANIFICADO)
  substituteUserId  String?          @map("substitute_user_id")
  substituteUser    User?            @relation("ShiftAssignmentSubstitute", fields: [substituteUserId], references: [id], onDelete: SetNull)
  notes             String?
  createdById       String           @map("created_by_id")
  createdBy         User             @relation("ShiftAssignmentCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@unique([tenantId, userId, date, shift])
  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, userId])
  @@index([tenantId, unitId])
  @@map("shift_assignments")
}

/// Cierre de turno firmado (RF-PRO-008/009/010/013).
///
/// Evolución del módulo /relevo (clinicalNotes.nursing.listForShiftHandover).
/// El listForShiftHandover SIGUE FUNCIONANDO (lee notas del turno por centro/unidad):
/// este modelo es el REGISTRO PERSISTE DEL CIERRE, que complementa al listador.
///
/// Firma simple (RF-PRO-013): el par closedById (userId autenticado) + closedAt
/// (timestamp del servidor) ES la firma. La firma avanzada eIDAS queda pendiente
/// de Q-008 (decisión del CIO).
///
/// @@unique por [tenantId, centerId, unitId, date, shift] — un cierre por
/// turno/unidad/día. unitId puede ser NULL (cierre a nivel de centro completo).
/// La unicidad con NULL se gestiona con dos índices parciales en la migración.
///
/// Sin residentId → no entra en dsar-registry.
///
/// Permisos: care:write para cerrar/firmar (AUXILIAR/SANITARIO/DIRECTOR).
///           care:read para leer (personal entrante).
model ShiftHandover {
  id               String           @id @default(cuid())
  tenantId         String           @map("tenant_id")
  centerId         String           @map("center_id")
  center           Center           @relation(fields: [centerId], references: [id], onDelete: Cascade)
  unitId           String?          @map("unit_id")
  unit             Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  date             DateTime         // día del turno
  shift            NursingNoteShift // reutiliza el enum existente
  summary          String           // observaciones generales del turno
  incidentsSummary String?          @map("incidents_summary") // incidencias
  pendingTasks     String?          @map("pending_tasks")     // pendientes para el siguiente turno
  // Firma simple (RF-PRO-013): userId autenticado + timestamp servidor
  closedById       String           @map("closed_by_id")
  closedBy         User             @relation(fields: [closedById], references: [id])
  closedAt         DateTime         @default(now()) @map("closed_at")
  createdAt        DateTime         @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, centerId, date])
  @@map("shift_handovers")
}

/// Hilo de mensajería bidireccional entre un familiar y el centro (COM-002).
/// Pertenece a un residente; el familiar vinculado y el staff del tenant participan.
///
/// NOTA Q-004: adjuntos de fichero en mensajes quedan fuera de alcance hasta
/// que se resuelva el object storage (Q-004).
model MessageThread {
  id            String               @id @default(cuid())
  tenantId      String               @map("tenant_id")
  residentId    String               @map("resident_id")
  resident      Resident             @relation(fields: [residentId], references: [id], onDelete: Cascade)
  subject       String
  category      MessageThreadCategory @default(GENERAL)
  status        MessageThreadStatus   @default(ABIERTO)
  createdById   String               @map("created_by_id")
  createdBy     User                 @relation("ThreadCreatedBy", fields: [createdById], references: [id])
  lastMessageAt DateTime             @default(now()) @map("last_message_at")
  createdAt     DateTime             @default(now()) @map("created_at")

  messages Message[]

  @@index([tenantId])
  @@index([residentId])
  @@index([lastMessageAt])
  @@map("message_threads")
}

/// Mensaje dentro de un hilo. Registra si fue leído por el staff y por la familia.
model Message {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  threadId        String        @map("thread_id")
  thread          MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId        String        @map("author_id")
  author          User          @relation("MessageAuthor", fields: [authorId], references: [id])
  body            String
  readByStaffAt   DateTime?     @map("read_by_staff_at")
  readByFamilyAt  DateTime?     @map("read_by_family_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([threadId])
  @@map("messages")
}
